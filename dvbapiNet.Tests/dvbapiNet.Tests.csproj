<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net481</TargetFramework>
    <PlatformTarget>x86</PlatformTarget>
    <Platforms>x86</Platforms>
    <IsPackable>false</IsPackable>
    <LangVersion>7.3</LangVersion>
    <RootNamespace>dvbapiNet.Tests</RootNamespace>
    <AssemblyName>dvbapiNet.Tests</AssemblyName>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="xunit" Version="2.6.5" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.6" />
  </ItemGroup>

  <!-- Reference the pre-built DLL (avoids triggering DllExport build chain via dotnet CLI). -->
  <ItemGroup>
    <Reference Include="dvbapiNet">
      <HintPath>..\dvbapiNet\bin\x86\Release\dvbapiNet.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
</Project>
